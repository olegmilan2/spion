rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
    }

    match /rooms/{roomId}/players/{playerId} {
      allow read, write: if request.auth != null;
    }

    match /rooms/{roomId}/votes/{voteId} {
      allow read, write: if request.auth != null;
    }
  }
}
